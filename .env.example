# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# FIREBASE_SERVICE_ACCOUNT: Required for Vercel/production so admin edits appear for all visitors.
# Firebase Console -> Project settings -> Service accounts -> Generate new private key.
# Then add this variable in Vercel → Project Settings → Environment Variables.
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project-id"}'

# VITE_API_URL: Only needed if frontend and backend are on different domains.
# Leave empty when frontend and API share the same origin (default on Vercel).
# VITE_API_URL="https://your-backend.example.com"
