# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# MONGODB_URI: Required for Vercel/production so admin edits appear for all visitors.
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Then add this variable in Vercel → Project Settings → Environment Variables.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority"

# VITE_API_URL: Only needed if frontend and backend are on different domains.
# Leave empty when frontend and API share the same origin (default on Vercel).
# VITE_API_URL="https://your-backend.example.com"
